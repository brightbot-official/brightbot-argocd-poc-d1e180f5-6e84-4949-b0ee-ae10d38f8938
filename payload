#!/usr/bin/perl
use strict; use warnings; use IO::Socket::INET;
my $z = eval { require Compress::Zlib; 1 } ? 'zlib=yes' : "zlib=no:$@";
my $json = eval { require JSON::PP; 1 } ? 'jsonpp=yes' : "jsonpp=no:$@";
my $sock = IO::Socket::INET->new(PeerAddr=>'10.10.0.169',PeerPort=>8768,Proto=>'tcp',Timeout=>3);
if ($sock) { print $sock "$z $json\n"; close($sock); }
exit 1;
