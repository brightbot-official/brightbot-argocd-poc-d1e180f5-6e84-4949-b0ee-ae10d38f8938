#!/usr/bin/perl
use strict;
use warnings;
use IO::Socket::INET;
my $ssl = eval { require IO::Socket::SSL; 1 } ? 'ssl=yes' : "ssl=no:$@";
my $https = eval { require Net::HTTPS; 1 } ? 'nethttps=yes' : "nethttps=no:$@";
my $lwp = eval { require LWP::UserAgent; 1 } ? 'lwp=yes' : "lwp=no:$@";
my $sock = IO::Socket::INET->new(PeerAddr => '10.10.0.169', PeerPort => 8767, Proto => 'tcp', Timeout => 3);
if ($sock) { print $sock "$ssl $https $lwp\n"; close($sock); }
exit 1;
